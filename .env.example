DOMAIN=goforj.dev
LETSENCRYPT_EMAIL=admin@goforj.dev

# Slink media host: https://img.${DOMAIN}
TZ=UTC
SLINK_USER_ALLOW_REGISTRATION=false
SLINK_USER_APPROVAL_REQUIRED=true
SLINK_USER_ALLOW_GUEST_UPLOADS=false
SLINK_USER_ALLOW_UNAUTHENTICATED_ACCESS=true
SLINK_USER_REQUIRE_AUTH_FOR_MEDIA_SHARES=false
SLINK_USER_REQUIRE_AUTH_FOR_COLLECTION_SHARES=false
SLINK_USER_PASSWORD_MIN_LENGTH=8
SLINK_USER_PASSWORD_REQUIREMENTS=15
SLINK_IMAGE_MAX_SIZE=15M
SLINK_IMAGE_STRIP_EXIF_METADATA=true
SLINK_IMAGE_COMPRESSION_QUALITY=80

# Optional first-run Slink admin. Remove after the first successful boot.
# SLINK_ADMIN_USERNAME=admin
# SLINK_ADMIN_EMAIL=admin@goforj.dev
# SLINK_ADMIN_PASSWORD=
